# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID (get from @userinfobot on Telegram)
TELEGRAM_CHAT_ID=your_chat_id_here

# Bybit P2P API credentials (https://www.bybit.com/app/user/api-management)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# Scan interval in seconds (default: 60)
SCAN_INTERVAL=60

# Price thresholds for PKR
BUY_PRICE_THRESHOLD=285
SELL_PRICE_THRESHOLD=295
